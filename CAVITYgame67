MazeTab:CreateToggle({Name = "Auto Activate Buttons", Callback = function(Value)
    if Value then
        local p, c = game.Players.LocalPlayer, game.Players.LocalPlayer.Character
        local hrp = c and c:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local startPos = hrp.CFrame
        local RoomSpecialFifty = workspace.Rooms:FindFirstChild("RoomSpecialFifty")
        if RoomSpecialFifty then
            for _, child in pairs(RoomSpecialFifty:GetChildren()) do
                if child.Name == "Button" and child:IsA("Model") then
                    local hrpbuttontp = child:FindFirstChild("hrpbuttontp")
                    if hrpbuttontp then
                        hrp.CFrame = hrpbuttontp.CFrame
                        task.wait(6)
                        local prompt = hrpbuttontp:FindFirstChildOfClass("ProximityPrompt")
                        if prompt then fireproximityprompt(prompt) end
                    end
                end
            end
            task.wait(1); hrp.CFrame = startPos
        end
    end
end})

