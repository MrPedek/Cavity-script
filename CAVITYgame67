local Window = Rayfield:CreateWindow({Name = " [ ⚓ ] CAVITY • PRO ", ConfigurationSaving = { Enabled = false }})
local RunService = game:GetService("RunService")

local Settings = {
    AutoEnabled = false, AutoDirt = false, AutoEnterDoors = false, AutoBreakDoors = false, SelectedItems = {},
    EspCoral = false, EspBurger = false, EspCola = false, EspAxe = false, EspBubble = false, EspMonsters = false, EspDoors = false, EspButtons = false, EspText = false,
    SkillCount = 1, WalkSpeed = 16,
    ColorCoral = Color3.fromRGB(255, 255, 0), ColorBurger = Color3.fromRGB(218, 165, 32), ColorCola = Color3.fromRGB(40, 40, 40),
    ColorAxe = Color3.fromRGB(139, 69, 19), ColorBubble = Color3.fromRGB(0, 191, 255),
    ColorMonsters = Color3.fromRGB(255, 0, 0), ColorDoors = Color3.fromRGB(0, 255, 0),
    ColorFakeDoors = Color3.fromRGB(255, 0, 0), ColorButtons = Color3.fromRGB(255, 255, 255)
}

local UsedDoors = {}
local BlacklistFolders = {["Shop"] = true, ["Upgrades"] = true, ["RoomCards"] = true, ["RoomShop"] = true, ["ShopRoom"] = true}
local function MatchName(objName, targetName) return string.match(string.lower(objName), string.lower(targetName)) ~= nil end

local function TryCollect(obj)
    local parent = obj.Parent
    while parent and parent ~= game:GetService("Workspace") do
        if BlacklistFolders[parent.Name] then return end
        parent = parent.Parent
    end
    if string.match(obj.Name, "Fake") or obj.Name == "Sick Coral" then return end
    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt and prompt.ActionText ~= "Break" then prompt.HoldDuration = 0; fireproximityprompt(prompt) end
end

local function TriggerSkills()
    local sf = game:GetService("ReplicatedStorage"):FindFirstChild("Events") and game:GetService("ReplicatedStorage").Events:FindFirstChild("Skills")
    if sf then for _, s in pairs(sf:GetChildren()) do if s:IsA("RemoteEvent") then for i = 1, Settings.SkillCount do s:FireServer() end end end end
end

task.spawn(function()
    while task.wait(0.1) do
        local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum and hum.WalkSpeed ~= Settings.WalkSpeed then hum.WalkSpeed = Settings.WalkSpeed end
        
        if Settings.AutoEnabled then
            for _, obj in pairs(workspace:GetDescendants()) do
                if (Settings.AutoDirt and obj.Name == "Dirt") then TryCollect(obj) end
                for _, item in pairs(Settings.SelectedItems) do if MatchName(obj.Name, item) then TryCollect(obj) end end
            end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not Settings.AutoEnterDoors and not Settings.AutoBreakDoors then return end
    local humRoot = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not humRoot then return end
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if (obj.Name == "HRPtppos") then
            if (humRoot.Position - obj.Position).Magnitude < 10 then
                local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    prompt.HoldDuration = 0
                    if Settings.AutoEnterDoors and not string.find(prompt.ActionText, "Break") and not UsedDoors[obj] then
                        fireproximityprompt(prompt)
                        UsedDoors[obj] = true
                    elseif Settings.AutoBreakDoors and string.find(prompt.ActionText, "Break") then
                        fireproximityprompt(prompt)
                    end
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait(1) do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj.Name == "EspContainer" and (not obj.Parent or not obj.Parent:IsDescendantOf(workspace)) then obj:Destroy() end
        end
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:FindFirstChild("EspContainer") or obj:FindFirstAncestor(game.Players.LocalPlayer.Name) then continue end
            local color, label = nil, nil
            if Settings.EspDoors and (obj.Name == "HRPtppos" or obj.Name == "HRPtpposFAKEOne") then color, label = (obj.Name == "HRPtppos" and Settings.ColorDoors or Settings.ColorFakeDoors), (obj.Name == "HRPtppos" and "Door" or "Fake")
            elseif Settings.EspButtons and obj.Name == "hrpbuttontp" then color, label = Settings.ColorButtons, "Button"
            elseif Settings.EspCoral and (obj.Name == "Coral" or obj.Name == "BigCoral") then color, label = Settings.ColorCoral, "Coral"
            elseif Settings.EspBurger and MatchName(obj.Name, "Burger") then color, label = Settings.ColorBurger, "Burger"
            elseif Settings.EspCola and MatchName(obj.Name, "Cola") then color, label = Settings.ColorCola, "Cola"
            elseif Settings.EspAxe and MatchName(obj.Name, "Axe") then color, label = Settings.ColorAxe, "Axe"
            elseif Settings.EspBubble and MatchName(obj.Name, "Bubble") then color, label = Settings.ColorBubble, "Bubble"
            elseif Settings.EspMonsters and (obj.Name == "MubrikTheEater" or obj.Name == "Drowned" or obj.Name == "Trap") then
                color = Settings.ColorMonsters
                label = (obj.Name == "Drowned" and "Zombie") or (obj.Name == "Trap" and "Trap") or "Monster"
            end
            if color then 
                local part = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)) or (obj:IsA("BasePart") and obj)
                if part then
                    local c = Instance.new("Folder", obj); c.Name = "EspContainer"
                    local b = Instance.new("BoxHandleAdornment", c); b.Adornee = part; b.Size = part.Size + Vector3.new(0.5,0.5,0.5); b.Color3 = color; b.AlwaysOnTop = true; b.ZIndex = 5; b.Transparency = 0.3
                    if Settings.EspText then
                        local g = Instance.new("BillboardGui", c); g.Name = "EspGui"; g.Size = UDim2.new(0,100,0,50); g.AlwaysOnTop = true; g.StudsOffset = Vector3.new(0,3,0)
                        local l = Instance.new("TextLabel", g); l.Size = UDim2.new(1,0,1,0); l.Text = label; l.TextColor3 = color; l.BackgroundTransparency = 1; l.TextStrokeTransparency = 0
                    end
                end
            end
        end
    end
end)

